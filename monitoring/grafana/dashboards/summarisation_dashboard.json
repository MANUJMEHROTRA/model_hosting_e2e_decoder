{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Summarisation API Dashboard",
  "uid": "summarisation-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Throughput (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(summarise_requests_total[1m])) by (endpoint)",
          "legendFormat": "{{ endpoint }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Latency p50 / p90 / p95 / p99",
      "type": "timeseries",
      "description": "PromQL: histogram_quantile(0.95, sum(rate(summarise_request_latency_seconds_bucket[5m])) by (le, endpoint))\n\nThis is the KEY metric. p95 = 95th percentile latency = the latency exceeded by only 5% of requests. In production SLAs you often say 'p95 < 500ms'.",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(summarise_request_latency_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p50 {{ endpoint }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.90, sum(rate(summarise_request_latency_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p90 {{ endpoint }}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(summarise_request_latency_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p95 {{ endpoint }}",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(summarise_request_latency_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p99 {{ endpoint }}",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "100 * sum(rate(summarise_requests_total{status='error'}[5m])) / sum(rate(summarise_requests_total[5m]))",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]
        }}
      }
    },
    {
      "id": 4,
      "title": "Model Memory Usage (MB)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "model_memory_mb",
          "legendFormat": "Model MB",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0, "max": 8192,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4096 },
              { "color": "red", "value": 7168 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Tokens Processed / sec",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(tokens_processed_total[1m])",
          "legendFormat": "{{ direction }} tokens/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "p95 Latency — Stat Panel (SLA tracker)",
      "type": "stat",
      "description": "Current p95 latency. Alert if > 5s.",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(summarise_request_latency_seconds_bucket[5m])) by (le))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red",    "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "p90 Latency — Stat Panel",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.90, sum(rate(summarise_request_latency_seconds_bucket[5m])) by (le))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          }
        }
      }
    }
  ]
}
